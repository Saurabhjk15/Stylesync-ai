# ─────────────────────────────────────────────
# StyleSync AI — Backend Environment Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8080

# ─── Database ────────────────────────────────
# Get: https://cloud.mongodb.com → Create Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/arfashion?retryWrites=true&w=majority

# ─── Auth ────────────────────────────────────
JWT_SECRET=some-long-random-secret-string-here
JWT_EXPIRE=7d

# Google OAuth Client ID (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── ML Service ──────────────────────────────
ML_SERVICE_URL=http://localhost:5000

# ─── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────
# AI Services
# ─────────────────────────────────────────────

# Groq API — Style DNA (FREE) https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Gemini API — Fallback (FREE) https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# Google Custom Search (FREE 100/day)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id

# Serper.dev — Image search (FREE 2,500/month) https://serper.dev
SERPER_API_KEY=your_serper_api_key

# Replicate — IDM-VTON fallback https://replicate.com
REPLICATE_API_KEY=your_replicate_api_key

# LightX — Virtual Try-On https://www.lightxeditor.com/api/
LIGHTX_API_KEY=your_lightx_api_key

# IDM-VTON provider: 'huggingface' (free) | 'replicate' (paid)
VTON_PROVIDER=huggingface

# HuggingFace Inference API https://huggingface.co/settings/tokens
HF_INFERENCE_API_KEY=hf_your_hf_key_here

# Remove.bg API (50 free/month) https://www.remove.bg/api
REMOVEBG_API_KEY=your_removebg_api_key

# ─────────────────────────────────────────────
# Supabase — Image Storage
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────────
# Contact Form — Resend Email (FREE 100/day)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
GMAIL_USER=your_email@gmail.com
